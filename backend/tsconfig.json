{
  "compilerOptions": {
    /* =========================
       🎯 CORE (NODE + ESM SAFE)
    ========================= */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* =========================
       📁 PROJECT STRUCTURE
    ========================= */
    "rootDir": "./src",
    "outDir": "./dist",

    /* =========================
       ⚡ BUILD CONTROL (CRITICAL FIX)
    ========================= */
    "noEmit": false,
    "declaration": false,
    "emitDeclarationOnly": false,

    /* =========================
       ⚡ IMPORT SYSTEM (ESM SAFE)
    ========================= */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* =========================
       🔐 STRICTNESS (BALANCED)
    ========================= */
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strictFunctionTypes": false,
    "noImplicitOverride": true,

    /* =========================
       🧠 TYPES
    ========================= */
    "types": ["node"],

    /* =========================
       🧹 BUILD STABILITY
    ========================= */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* =========================
       🚀 PERFORMANCE
    ========================= */
    "incremental": false,
    "sourceMap": true,

    /* =========================
       🧩 NODE COMPATIBILITY
    ========================= */
    "useDefineForClassFields": false,

    /* =========================
       🔥 SAFETY
    ========================= */
    "allowJs": false,
    "checkJs": false,

    /* =========================
       🛠 DEBUG (IMPORTANT)
    ========================= */
    "traceResolution": false
  },

  /* =========================
     📦 FILE DETECTION (CRITICAL FIX)
  ========================= */
  "include": ["./src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}